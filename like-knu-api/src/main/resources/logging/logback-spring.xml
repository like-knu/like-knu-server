<?xml version="1.0" encoding="UTF-8"?>

<configuration>
    <timestamp key="BY_DATE" datePattern="yyyy-MM-dd" />
    <conversionRule conversionWord="clr" converterClass="org.springframework.boot.logging.logback.ColorConverter" />
    <property name="LOG_PATTERN"
        value="%yellow([%d{yyyy-MM-dd HH:mm:ss.SSS}]) %magenta([%18.18thread]) %clr(%-5level) | %blue(%32.32logger{32}) | %msg%n" />

    <include resource="logging/console-appender.xml" />
    <include resource="logging/file-appender.xml" />
    <include resource="logging/json-file-appender.xml" />

    <springProfile name="prod">
        <springProperty scope="local" name="SLACK_WEBHOOK" source="slack.error-webhook" />
        <appender name="SLACK-ERROR" class="com.woopaca.likeknu.logging.SlackErrorAppender">
            <webhookUrl>${SLACK_WEBHOOK}</webhookUrl>
            <excludePatterns>IOException: Broken pipe|Failed to fetch Naver real-time bus information.</excludePatterns>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
        </appender>
    </springProfile>

    <springProfile name="local,local-dev,test">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="FILE" />
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="JSON-FILE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="SLACK-ERROR" />
        </root>
    </springProfile>
</configuration>
